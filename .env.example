# .env.example — ShopSafe
# Copier en .env et remplir les valeurs. Le fichier .env ne doit JAMAIS
# être commité dans git (ajouté dans .gitignore).
#
# En production, utiliser un gestionnaire de secrets :
#   - HashiCorp Vault : vault kv get secret/shopsafe
#   - AWS Secrets Manager : aws secretsmanager get-secret-value
#   - Kubernetes Secrets : kubectl create secret generic shopsafe-secrets
#   - Docker Swarm : docker secret create

# ── Obligatoire en production ──────────────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_DE_64_CHARS

# ── Environnement ──────────────────────────────────────────────────
# Valeurs possibles : development | production | testing
FLASK_ENV=production

# ── Base de données ────────────────────────────────────────────────
DATABASE_PATH=shopsafe.db

# ── Rate limiting (Redis recommandé en production) ─────────────────
# REDIS_URL=redis://localhost:6379/0

# ── Port ──────────────────────────────────────────────────────────
PORT=8080
